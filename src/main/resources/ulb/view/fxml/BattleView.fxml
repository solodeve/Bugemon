<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane fx:id="battleRootPane" prefHeight="650.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ulb.view.battle.BattleView"
            styleClass="battle-root">

   <stylesheets>
       <URL value="@../css/global.css"/>
       <URL value="@../css/battle.css"/>
   </stylesheets>

   <VBox fx:id="enemyInfoPanel"
         spacing="8.0"
         prefWidth="300.0"
         AnchorPane.topAnchor="40.0"
         AnchorPane.rightAnchor="270.0"
         styleClass="enemy-info-panel">
      <Label fx:id="enemyNameLabel"
             text="Enemy Bugemon"
             styleClass="battle-name-label"/>

      <Label fx:id="enemyElementLabel"
             text="ELEMENT"
             styleClass="battle-element-label"/>

      <ProgressBar fx:id="enemyHpBar"
                   prefWidth="265.0"
                   progress="1.0"/>

      <Label fx:id="enemyHpLabel"
             text="HP : 100 / 100"
             styleClass="battle-hp-label"/>
   </VBox>

   <ImageView fx:id="enemySprite"
              fitHeight="190.0"
              fitWidth="190.0"
              preserveRatio="true"
              pickOnBounds="true"
              AnchorPane.topAnchor="200.0"
              AnchorPane.rightAnchor="330.0"/>

   <VBox fx:id="playerInfoPanel"
         spacing="8.0"
         prefWidth="320.0"
         AnchorPane.leftAnchor="250.0"
         AnchorPane.topAnchor="140.0"
         styleClass="player-info-panel">
      <Label fx:id="playerNameLabel"
             text="Player Bugemon"
             styleClass="battle-name-label"/>

      <Label fx:id="playerElementLabel"
             text="ELEMENT"
             styleClass="battle-element-label"/>

      <ProgressBar fx:id="playerHpBar"
                   prefWidth="285.0"
                   progress="1.0"/>

      <Label fx:id="playerHpLabel"
             text="HP : 100 / 100"
             styleClass="battle-hp-label"/>

      <ProgressBar fx:id="playerXpBar"
                   prefWidth="285.0"
                   progress="0.0"
                   style="-fx-accent: gold;"/>

      <Label fx:id="playerXpLabel"
             text="XP : 0 / 100"
             styleClass="battle-xp-label"/>

      <ProgressBar fx:id="playerSpecialBar"
                   prefWidth="285.0"
                   progress="0.0"
                   visible="false"
                   managed="false"
                   style="-fx-accent: crimson;"/>

      <Label fx:id="playerSpecialLabel"
             text="Special : 0 / 0"
             visible="false"
             managed="false"
             styleClass="battle-special-label"/>
   </VBox>

   <ImageView fx:id="playerSprite"
              fitHeight="220.0"
              fitWidth="220.0"
              preserveRatio="true"
              pickOnBounds="true"
              AnchorPane.leftAnchor="300.0"
              AnchorPane.topAnchor="350.0"/>

   <StackPane fx:id="dialoguePanel"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.bottomAnchor="20.0">
      <Rectangle fx:id="dialogRect"
                 arcHeight="14.0"
                 arcWidth="14.0"
                 fill="#fdfdfde8"
                 height="125.0"
                 width="450.0"
                 stroke="BLACK"
                 strokeWidth="2.0"/>

      <Label fx:id="messageLabel"
             wrapText="true"
             prefWidth="400.0"
             visible="false"
             managed="false"
             styleClass="battle-message-label"
             alignment="TOP_LEFT"
             StackPane.alignment="TOP_LEFT">
         <StackPane.margin>
            <Insets top="15.0" left="18.0" right="18.0" bottom="15.0"/>
         </StackPane.margin>
      </Label>

      <VBox fx:id="dialogBox"
            spacing="6"
            StackPane.alignment="TOP_LEFT">
         <StackPane.margin>
            <Insets top="15.0" left="18.0" right="18.0" bottom="15.0"/>
         </StackPane.margin>
      </VBox>

   </StackPane>

   <!-- Transparent overlay pane for elemental particle animations -->
   <AnchorPane fx:id="animationOverlay"
               mouseTransparent="true"
               AnchorPane.topAnchor="0.0"
               AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0"
               styleClass="animation-overlay"/>

   <StackPane fx:id="actionPanel"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.bottomAnchor="20.0">
      <Rectangle arcHeight="14.0"
                 arcWidth="14.0"
                 fill="#ffffffea"
                 height="195.0"
                 width="490.0"
                 stroke="BLACK"
                 strokeWidth="2.0"/>

      <GridPane alignment="CENTER" hgap="12.0" vgap="12.0">
         <columnConstraints>
            <ColumnConstraints prefWidth="214.0"/>
            <ColumnConstraints prefWidth="214.0"/>
         </columnConstraints>

         <rowConstraints>
            <RowConstraints prefHeight="72.0"/>
            <RowConstraints prefHeight="72.0"/>
         </rowConstraints>

         <Button fx:id="attackButton"
                 text="Attack"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="action-btn"
                 GridPane.columnIndex="0"
                 GridPane.rowIndex="0"/>

         <Button fx:id="teamButton"
                 text="Team"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="action-btn"
                 GridPane.columnIndex="1"
                 GridPane.rowIndex="0"/>

         <Button fx:id="itemsButton"
                 text="Objects"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="action-btn"
                 GridPane.columnIndex="0"
                 GridPane.rowIndex="1"/>

         <Button fx:id="giveUpButton"
                 text="Give Up"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="action-btn"
                 GridPane.columnIndex="1"
                 GridPane.rowIndex="1"/>

         <Button fx:id="skill1Button"
                 text="Sort 1"
                 visible="false"
                 managed="false"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="skill-btn"
                 GridPane.columnIndex="0"
                 GridPane.rowIndex="0"/>

         <Button fx:id="skill2Button"
                 text="Sort 2"
                 visible="false"
                 managed="false"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="skill-btn"
                 GridPane.columnIndex="1"
                 GridPane.rowIndex="0"/>

         <Button fx:id="skill3Button"
                 text="Sort 3"
                 visible="false"
                 managed="false"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="skill-btn"
                 GridPane.columnIndex="0"
                 GridPane.rowIndex="1"/>

         <Button fx:id="returnButton"
                 text="Back"
                 visible="false"
                 managed="false"
                 maxWidth="Infinity"
                 maxHeight="Infinity"
                 styleClass="skill-btn"
                 GridPane.columnIndex="1"
                 GridPane.rowIndex="1"/>
      </GridPane>
   </StackPane>

   <Button fx:id="specialButton"
           text="Domain"
           prefWidth="150.0"
           prefHeight="58.0"
           visible="false"
           managed="false"
           styleClass="special-button"
           AnchorPane.rightAnchor="530.0"
           AnchorPane.bottomAnchor="32.0"/>

</AnchorPane>
