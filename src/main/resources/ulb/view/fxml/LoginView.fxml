<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ulb.view.menu.LoginView"
            prefHeight="650.0" prefWidth="1000.0"
            styleClass="login-root">

    <stylesheets>
        <URL value="@../css/global.css"/>
        <URL value="@../css/login.css"/>
    </stylesheets>

    <VBox alignment="CENTER"
          spacing="16.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">

        <padding>
            <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
        </padding>

        <ImageView fitWidth="550"
                   fitHeight="440"
                   preserveRatio="true"
                   smooth="true">
            <image>
                <Image url="/ulb/assets/png/backgrounds/logo.png"/>
            </image>
        </ImageView>

        <TextField fx:id="usernameField"
                   promptText="Username"
                   prefWidth="380.0"
                   prefHeight="44.0"
                   maxWidth="380.0"
                   styleClass="input-field"/>

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       prefWidth="380.0"
                       prefHeight="44.0"
                       maxWidth="380.0"
                       onAction="#handleLogin"
                       styleClass="input-field"/>

        <Label fx:id="messageLabel"
               visible="false"
               managed="false"
               wrapText="true"/>

        <Button fx:id="loginButton"
                text="LOG IN"
                onAction="#handleLogin"
                prefWidth="380.0"
                prefHeight="48.0"
                styleClass="btn-login"/>

        <Button fx:id="registerButton"
                text="SIGN UP"
                onAction="#handleRegister"
                prefWidth="380.0"
                prefHeight="48.0"
                styleClass="btn-register"/>

        <Button fx:id="quitButton"
                text="QUIT"
                onAction="#handleQuit"
                prefWidth="380.0"
                prefHeight="48.0"
                styleClass="btn-quit"/>
    </VBox>
</AnchorPane>
