<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ulb.view.menu.SettingsView"
            prefWidth="1280"
            prefHeight="760"
            styleClass="settings-root">

    <stylesheets>
        <URL value="@../css/global.css"/>
        <URL value="@../css/settings.css"/>
    </stylesheets>

    <top>
        <Label text="Game Controls"
               BorderPane.alignment="CENTER"
               styleClass="settings-title">
            <BorderPane.margin>
                <Insets top="28" bottom="12"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <VBox alignment="CENTER" fillWidth="true" spacing="18" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets top="16" right="70" bottom="18" left="70" />
            </BorderPane.margin>

            <VBox maxWidth="940"
                  spacing="18"
                  styleClass="settings-panel">
                <children>
                    <Label text="Navigation menu"
                           styleClass="settings-section-title"/>

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <children>
                            <Label text="↑↓←→"
                                   styleClass="key-arrow"/>
                            <Label text="Navigate through menus"
                                   wrapText="true"
                                   styleClass="settings-action-label"/>
                        </children>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <children>
                            <Label text="ENTER"
                                   styleClass="key-enter"/>
                            <Label text="Open the selected button"
                                   wrapText="true"
                                   styleClass="settings-action-label"/>
                        </children>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <children>
                            <Label text="ESC"
                                   styleClass="key-esc"/>
                            <Label text="Go back"
                                   wrapText="true"
                                   styleClass="settings-action-label"/>
                        </children>
                    </HBox>

                    <Region prefHeight="10.0" />

                    <Label text="During the game"
                           styleClass="settings-section-title-in-game"/>

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <children>
                            <Label text="SPACE"
                                   styleClass="key-space"/>
                            <Label text="Skip dialogues"
                                   wrapText="true"
                                   styleClass="settings-action-label"/>
                        </children>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <children>
                            <Label text="E"
                                styleClass="key-e"/>
                            <Label text="Trigger Bugemon evolution when available"
                                wrapText="true"
                                styleClass="settings-action-label"/>
                        </children>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <children>
                            <Label text="ESC"
                                   styleClass="key-esc"/>
                            <Label text="Give up the match"
                                   wrapText="true"
                                   styleClass="settings-action-label"/>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="28" left="70" right="70" top="0" />
            </BorderPane.margin>
            <Button fx:id="btnBack"
                    text="Back"
                    onAction="#handleBack"
                    prefWidth="240"
                    prefHeight="54"
                    styleClass="btn-settings-back"/>
        </HBox>
    </bottom>
</BorderPane>
